import { Injectable, Logger } from '@nestjs/common';
import { HttpService } from '@nestjs/axios';
import { ConfigService } from '@nestjs/config';

@Injectable()
export class WechatTokenService {
  private readonly logger = new Logger(WechatTokenService.name);

  constructor(
    private readonly httpService: HttpService,
    private readonly configService: ConfigService,
  ) {}

  /**
   * 刷新微信token
   * 核心方法：使用refresh_token获取新的access_token
   */
  async refreshToken(refreshToken: string): Promise<any> {
    const appId = this.configService.get<string>('WECHAT_APP_ID');
    const appSecret = this.configService.get<string>('WECHAT_APP_SECRET');

    const url = 'https://api.weixin.qq.com/sns/oauth2/refresh_token';

    try {
      const response = await this.httpService.post(url, null, {
        params: {
          appid: appId,
          grant_type: 'refresh_token',
          refresh_token: refreshToken,
        },
      }).toPromise();

      const data = response.data;

      if (data.errcode && data.errcode !== 0) {
        throw new Error(`微信刷新token失败: ${data.errmsg} (错误码: ${data.errcode})`);
      }

      if (!data.access_token) {
        throw new Error('刷新token失败: 响应中没有access_token');
      }

      this.logger.log(`微信token刷新成功，openid: ${data.openid}`);

      return {
        access_token: data.access_token,
        expires_in: data.expires_in || 7200,
        refresh_token: data.refresh_token,
        openid: data.openid,
        unionid: data.unionid,
        scope: data.scope,
      };

    } catch (error) {
      this.logger.error('微信token刷新失败:', error);
      throw error;
    }
  }

  /**
   * 验证token是否有效
   */
  async validateToken(accessToken: string): Promise<boolean> {
    try {
      // 调用微信API验证token
      const response = await this.httpService.get('https://api.weixin.qq.com/sns/auth', {
        params: {
          access_token: accessToken,
          openid: 'test', // openid不用于验证，只是必需参数
        },
      }).toPromise();

      const data = response.data;

      // errcode为0表示token有效
      return data.errcode === 0;

    } catch (error) {
      this.logger.error('Token验证失败:', error);
      return false;
    }
  }

  /**
   * 获取所有用户的token状态
   */
  async getAllTokensStatus(): Promise<any[]> {
    // 这里应该从数据库中查询所有用户的token状态
    // 简化实现，返回示例数据
    return [
      {
        openid: 'openid1',
        status: 'valid',
        expires_at: Date.now() + 2 * 60 * 60 * 1000,
        refresh_expires_at: Date.now() + 25 * 24 * 60 * 60 * 1000,
      },
      {
        openid: 'openid2',
        status: 'expiring_soon',
        expires_at: Date.now() + 30 * 60 * 1000,
        refresh_expires_at: Date.now() + 2 * 24 * 60 * 60 * 1000,
      },
    ];
  }

  /**
   * 检查并刷新所有token
   */
  async checkAndRefreshAllTokens(): Promise<any> {
    const tokensStatus = await this.getAllTokensStatus();

    let refreshed = 0;
    let failed = 0;
    const errors: string[] = [];

    for (const tokenStatus of tokensStatus) {
      try {
        // 检查是否需要刷新
        if (tokenStatus.status === 'expiring_soon' || tokenStatus.status === 'expired') {
          this.logger.log(`检查到用户 ${tokenStatus.openid} token需要刷新`);

          // 这里应该从数据库获取refresh_token
          const refreshToken = 'mock_refresh_token'; // 实际应该从数据库获取

          await this.refreshToken(refreshToken);
          refreshed++;
        }
      } catch (error) {
        failed++;
        errors.push(`用户 ${tokenStatus.openid}: ${error.message}`);
        this.logger.error(`刷新用户 ${tokenStatus.openid} token失败:`, error);
      }
    }

    return {
      total: tokensStatus.length,
      refreshed,
      failed,
      errors,
    };
  }
}
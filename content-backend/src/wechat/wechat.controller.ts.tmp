import {
  Controller,
  Post,
  Get,
  UseInterceptors,
  UploadedFile,
  Body,
  HttpCode,
  HttpStatus
} from '@nestjs/common';
import { FileInterceptor } from '@nestjs/platform-express';
import { WechatServerService } from './wechat.server.service';

@Controller('api/wechat')
export class WechatController {
  constructor(private readonly wechatService: WechatServerService) {}

  /**
   * 获取 access_token
   * 这个API用于前端获取最新的access_token状态
   */
  @Get('access-token')
  async getAccessToken() {
    try {
      const accessToken = await this.wechatService.getAccessToken();

      return {
        success: true,
        data: {
          access_token: accessToken,
          expires_in: 7200, // 2小时
        }
      };
    } catch (error) {
      return {
        success: false,
        error: error.message
      };
    }
  }

  /**
   * 检查服务状态
   */
  @Get('status')
  async checkStatus() {
    try {
      const status = await this.wechatService.checkStatus();
      return status;
    } catch (error) {
      return {
        status: 'error',
        message: error.message
      };
    }
  }

  /**
   * 上传图片
   * 直接使用微信API，无需用户授权
   */
  @Post('upload')
  @UseInterceptors(FileInterceptor('image'))
  async uploadImage(@UploadedFile() image: Express.Multer.File) {
    try {
      if (!image) {
        return {
          success: false,
          error: '没有上传图片文件'
        };
      }

      console.log('接收到图片上传请求:', image.originalname);

      const result = await this.wechatService.uploadImage(image);

      return {
        success: true,
        data: result,
        message: '图片上传成功'
      };

    } catch (error) {
      console.error('图片上传失败:', error);

      return {
        success: false,
        error: error.message,
        message: '图片上传失败'
      };
    }
  }

  /**
   * 批量上传图片
   */
  @Post('batch-upload')
  @UseInterceptors(FileInterceptor('images', { maxCount: 9 }))
  async batchUploadImages(@UploadedFile() images: Express.Multer.File[]) {
    try {
      if (!images || images.length === 0) {
        return {
          success: false,
          error: '没有上传图片文件'
        };
      }

      console.log('接收到批量图片上传请求:', images.length, '个文件');

      const results = await Promise.allSettled(
        images.map(image => this.wechatService.uploadImage(image))
      );

      const successCount = results.filter(r => r.status === 'fulfilled').length;
      const failedCount = results.length - successCount;

      return {
        success: failedCount === 0,
        message: `批量上传完成：成功 ${successCount} 个，失败 ${failedCount} 个`,
        data: {
          results: results.map((result, index) => ({
            filename: images[index].originalname,
            success: result.status === 'fulfilled',
            data: result.status === 'fulfilled' ? result.value : null,
            error: result.status === 'rejected' ? result.reason.message : null
          }))
        }
      };

    } catch (error) {
      console.error('批量图片上传失败:', error);

      return {
        success: false,
        error: error.message,
        message: '批量图片上传失败'
      };
    }
  }

  /**
   * 创建图文草稿
   */
  @Post('draft')
  async createDraft(@Body() articleData: any) {
    try {
      console.log('创建图文草稿:', articleData.title);

      const result = await this.wechatService.createDraft(articleData);

      return {
        success: true,
        data: result,
        message: '图文草稿创建成功'
      };

    } catch (error) {
      console.error('创建图文草稿失败:', error);

      return {
        success: false,
        error: error.message,
        message: '图文草稿创建失败'
      };
    }
  }

  /**
   * 发布图文消息
   */
  @Post('publish')
  async publishArticle(@Body() publishData: any) {
    try {
      console.log('发布图文消息:', publishData.title);

      // 构建发布请求
      const accessToken = await this.wechatService.getAccessToken();

      const response = await fetch(
        `https://api.weixin.qq.com/cgi-bin/draft/publish?access_token=${accessToken}`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            media_id: publishData.media_id,
          }),
        }
      );

      const result = await response.json();

      if (result.errcode && result.errcode !== 0) {
        throw new Error(`发布失败: ${result.errmsg}`);
      }

      return {
        success: true,
        data: result,
        message: '图文消息发布成功'
      };

    } catch (error) {
      console.error('发布图文消息失败:', error);

      return {
        success: false,
        error: error.message,
        message: '图文消息发布失败'
      };
    }
  }

  /**
   * 获取关注者列表（需要公众号关注权限）
   */
  @Get('followers')
  async getFollowers(@Query('next_openid') nextOpenid?: string) {
    try {
      const accessToken = await this.wechatService.getAccessToken();

      let url = `https://api.weixin.qq.com/cgi-bin/user/get?access_token=${accessToken}`;
      if (nextOpenid) {
        url += `&next_openid=${nextOpenid}`;
      }

      const response = await fetch(url);
      const result = await response.json();

      if (result.errcode && result.errcode !== 0) {
        throw new Error(`获取关注者失败: ${result.errmsg}`);
      }

      return {
        success: true,
        data: result,
        message: '获取关注者列表成功'
      };

    } catch (error) {
      console.error('获取关注者列表失败:', error);

      return {
        success: false,
        error: error.message,
        message: '获取关注者列表失败'
      };
    }
  }

  /**
   * 测试API连接
   */
  @Get('test')
  async testConnection() {
    try {
      // 测试获取access_token
      const accessToken = await this.wechatService.getAccessToken();

      // 测试获取IP白名单
      const response = await fetch(
        `https://api.weixin.qq.com/cgi-bin/getcallbackip?access_token=${accessToken}`
      );

      const result = await response.json();

      return {
        success: true,
        message: 'API连接测试成功',
        data: {
          access_token_valid: true,
          api_connection: true,
          callback_ip: result.ip_list
        }
      };

    } catch (error) {
      console.error('API连接测试失败:', error);

      return {
        success: false,
        message: 'API连接测试失败',
        error: error.message
      };
    }
  }
}
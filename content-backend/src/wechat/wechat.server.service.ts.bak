import { Injectable, Logger } from '@nestjs/common';
import { ConfigService } from '@nestjs/config';
import { HttpService } from '@nestjs/axios';

@Injectable()
export class WechatServerService {
  private readonly logger = new Logger(WechatServerService.name);
  private accessToken: string = '';
  private tokenExpireTime: number = 0;

  constructor(
    private configService: ConfigService,
    private httpService: HttpService,
  ) {}

  /**
   * 获取公众号 access_token
   * 这是关键：使用公众号服务端授权，无30天限制
   */
  async getAccessToken(): Promise<string> {
    const now = Date.now();

    // 提前5分钟刷新token
    if (this.accessToken && now < this.tokenExpireTime - 5 * 60 * 1000) {
      return this.accessToken;
    }

    try {
      const appId = this.configService.get<string>('WECHAT_APP_ID');
      const appSecret = this.configService.get<string>('WECHAT_APP_SECRET');

      const url = `https://api.weixin.qq.com/cgi-bin/token?grant_type=client_credential&appid=${appId}&secret=${appSecret}`;

      this.logger.log('正在获取新的微信access_token...');

      const response = await this.httpService.get(url).toPromise();
      const data = response.data;

      if (data.errcode) {
        throw new Error(`获取access_token失败: ${data.errmsg}`);
      }

      this.accessToken = data.access_token;
      this.tokenExpireTime = now + data.expires_in * 1000;

      this.logger.log('access_token获取成功，有效期:', data.expires_in, '秒');

      return this.accessToken;

    } catch (error) {
      this.logger.error('获取access_token失败:', error);
      throw error;
    }
  }

  /**
   * 上传图片到微信素材库
   */
  async uploadImage(file: Express.Multer.File): Promise<any> {
    try {
      const accessToken = await this.getAccessToken();

      // 使用微信官方API上传
      const url = `https://api.weixin.qq.com/cgi-bin/media/upload?access_token=${accessToken}&type=image`;

      const formData = new FormData();
      formData.append('media', file.buffer, {
        filename: file.originalname,
        contentType: file.mimetype,
      });

      const response = await this.httpService.post(url, formData, {
        headers: {
          ...formData.getHeaders(),
        },
      }).toPromise();

      const data = response.data;

      if (data.errcode && data.errcode !== 0) {
        throw new Error(`上传图片失败: ${data.errmsg}`);
      }

      this.logger.log('图片上传成功:', file.originalname);
      return data;

    } catch (error) {
      this.logger.error('上传图片失败:', error);
      throw error;
    }
  }

  /**
   * 创建图文草稿
   */
  async createDraft(articleData: any): Promise<any> {
    try {
      const accessToken = await this.getAccessToken();

      const url = `https://api.weixin.qq.com/cgi-bin/draft/add?access_token=${accessToken}`;

      const response = await this.httpService.post(url, {
        articles: [articleData],
      }).toPromise();

      const data = response.data;

      if (data.errcode && data.errcode !== 0) {
        throw new Error(`创建草稿失败: ${data.errmsg}`);
      }

      this.logger.log('图文草稿创建成功');
      return data;

    } catch (error) {
      this.logger.error('创建草稿失败:', error);
      throw error;
    }
  }

  /**
   * 检查服务状态
   */
  async checkStatus(): Promise<any> {
    try {
      const accessToken = await this.getAccessToken();

      // 测试token是否有效
      const response = await this.httpService.get(
        `https://api.weixin.qq.com/cgi-bin/getcallbackip?access_token=${accessToken}`
      ).toPromise();

      return {
        status: 'success',
        message: '服务正常',
        tokenValid: true,
        tokenExpireTime: this.tokenExpireTime,
      };

    } catch (error) {
      return {
        status: 'error',
        message: error.message,
        tokenValid: false,
      };
    }
  }
}
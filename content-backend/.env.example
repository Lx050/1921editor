# 服务器配置
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# 飞书配置
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_BASE_APP_TOKEN=your_base_app_token_here
FEISHU_BASE_TABLE_ID=your_base_table_id_here

# 存储配置
DATA_DIR=./data
BACKUP_DIR=./backup

# 同步配置
BATCH_SIZE=100
RETRY_TIMES=3
SYNC_INTERVAL=300000

# 安全配置 - 生产环境必须设置强密码
JWT_SECRET=your_256_bit_jwt_secret_here_minimum_64_characters_long_random_string
API_KEY=your_api_key_here_at_least_32_characters

# 开发环境配置
SKIP_WEBHOOK_VERIFY=false
SKIP_API_KEY=false

# 日志配置
LOG_LEVEL=info
LOG_FILE=./data/logs/app.log

# 邮件配置
EMAIL_USER=your_email@domain.com
EMAIL_PASS=your_email_password_or_app_specific_password

# 缓存配置
CACHE_TTL=300
CACHE_MAX_ITEMS=100

# 🔒 安全提醒：
# 1. 不要将 .env 文件提交到版本控制系统
# 2. 生产环境必须使用强随机密钥
# 3. 定期轮换 JWT_SECRET 和 API_KEY
# 4. 使用环境变量或密钥管理服务管理敏感信息